# ─── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres connection string from Vercel dashboard
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://..."
DATABASE_URL_UNPOOLED="postgresql://..."


# ─── NextAuth / Auth.js ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The canonical URL of the portal
# Development: http://localhost:3000
# Production:  https://staff.northbridgemotors.co.nz
NEXTAUTH_URL="http://localhost:3000"

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Sender address shown on outgoing emails.
# MUST be from a domain you have verified in Resend — or use the shared
# sandbox address below for local testing (no domain verification needed).
# Local testing:  "Northbridge Motors <onboarding@resend.dev>"
# Production:     "Northbridge Motors <noreply@yourdomain.com>"
RESEND_FROM_EMAIL="Northbridge Motors <onboarding@resend.dev>"

# Base URL used for links inside emails (invite, password reset, etc.)
# Development: http://localhost:3000
# Production:  https://staff.northbridgemotors.co.nz
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Cron secret ───────────────────────────────────────────────────────────────
# Arbitrary secret that protects POST /api/cron/purge-finance
# Generate with: openssl rand -base64 32
# Must match the x-cron-secret header sent by your cron service
CRON_SECRET="your-cron-secret-here"

# ─── Seed (optional overrides) ────────────────────────────────────────────────
# These are only used by: npx prisma db seed
# Change the password immediately after first login.
SEED_OWNER_EMAIL="owner@northbridgemotors.co.nz"
SEED_OWNER_PASSWORD="ChangeMe!2025"
SEED_OWNER_NAME="Portal Owner"
