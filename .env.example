# ─── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres connection string from Vercel dashboard
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL="postgresql://..."

# ─── NextAuth / Auth.js ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# The canonical URL of the portal
# Development: http://localhost:3000
# Production:  https://staff.northbridgemotors.co.nz
NEXTAUTH_URL="http://localhost:3000"

# ─── Seed (optional overrides) ────────────────────────────────────────────────
# These are only used by: npx prisma db seed
# Change the password immediately after first login.
SEED_OWNER_EMAIL="owner@northbridgemotors.co.nz"
SEED_OWNER_PASSWORD="ChangeMe!2025"
SEED_OWNER_NAME="Portal Owner"
